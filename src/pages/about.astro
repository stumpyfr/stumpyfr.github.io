---
import PageHero from '@/components/sections/PageHero.astro';
import Button from '@/components/ui/Button.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/config/site';
---

<BaseLayout title="About" canonicalPath="/about">
  <PageHero
    title="About"
    copy="I work at the intersection of architecture, delivery, data, and AI. My background spans software engineering, platform strategy, large-scale transformation, and technical advisory work across complex environments."
  />

  <section class="section">
    <div class="container about-grid">
      <article class="body-copy">
        <h2 class="serif">Bio</h2>
        <p>
          Niels is a data, platform, and solution architect by specialization,
          a software engineer by education, and an advisor by practice.
        </p>
        <p>
          He helps organisations make high-consequence technology decisions in
          complex environments, where architecture, delivery, data, and AI have
          to work as one system rather than separate conversations.
        </p>
        <p>
          He writes at The Arkham Times and works with organisations through
          Arkham Advisory.
        </p>
      </article>

      <aside class="focus surface">
        <h2>Focus areas</h2>
        <ul>
          <li>Architecture strategy</li>
          <li>Data platforms</li>
          <li>AI enablement and judgment</li>
          <li>Transformation and technical decision support</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section why">
    <div class="container">
      <h2 class="serif">Why work with me</h2>
      <div class="reason-grid">
        <article>Architectural depth</article>
        <article>Systems thinking</article>
        <article>Technical and strategic bridge</article>
        <article>Independent judgment</article>
        <article>Experience in complex environments</article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container route-box surface texture">
      <div>
        <p class="eyebrow">Read More</p>
        <h2 class="serif">Two useful routes.</h2>
      </div>
      <div class="actions">
        <Button href={siteConfig.links.arkhamTimes} external>Arkham Times</Button>
        <Button href={siteConfig.links.arkhamAdvisory} variant="secondary" external>
          Arkham Advisory
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
    gap: 2rem;
    align-items: start;
  }

  .body-copy {
    display: grid;
    gap: 1rem;
    max-width: 760px;
  }

  h2 {
    margin: 0;
    color: var(--color-paper);
    font-size: clamp(2.4rem, 5vw, 4.8rem);
    line-height: 0.95;
  }

  .body-copy p {
    margin: 0;
    color: var(--color-fog);
    font-size: 1.08rem;
  }

  .focus {
    border-radius: 24px;
    padding: 1.5rem;
  }

  .focus h2 {
    font-family: inherit;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  ul {
    display: grid;
    gap: 0.8rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    color: var(--color-cloud);
  }

  li {
    padding-bottom: 0.8rem;
    border-bottom: 1px solid rgba(229, 231, 235, 0.1);
  }

  .reason-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.4rem;
  }

  .reason-grid article,
  .route-box {
    border: 1px solid var(--color-border);
    border-radius: 24px;
    background: rgba(17, 24, 39, 0.62);
  }

  .reason-grid article {
    min-height: 150px;
    padding: 1.2rem;
    color: var(--color-paper);
    font-weight: 800;
  }

  .route-box {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: clamp(1.5rem, 4vw, 3rem);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  @media (max-width: 980px) {
    .about-grid,
    .reason-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .about-grid,
    .reason-grid {
      grid-template-columns: 1fr;
    }

    .route-box {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
