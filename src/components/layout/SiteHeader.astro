---
import { externalLinkAttrs, externalNavLinks, navLinks } from '@/config/site';
import LogoMark from '@/components/ui/LogoMark.astro';
---

<header class="site-header" data-site-header>
  <div class="container nav-shell">
    <LogoMark />
    <nav class="desktop-nav" aria-label="Primary navigation">
      {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
    <nav class="external-nav" aria-label="External navigation">
      {externalNavLinks.map((link) => (
        <a href={link.href} {...externalLinkAttrs()}>{link.label}</a>
      ))}
    </nav>
    <button class="menu-button" type="button" aria-expanded="false" aria-controls="mobile-menu" data-menu-button>
      <span class="sr-only">Toggle navigation</span>
      <span aria-hidden="true"></span>
    </button>
  </div>
  <div id="mobile-menu" class="mobile-menu" hidden data-mobile-menu>
    <nav class="container" aria-label="Mobile navigation">
      {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
      {externalNavLinks.map((link) => (
        <a href={link.href} {...externalLinkAttrs()}>{link.label}</a>
      ))}
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector('[data-site-header]');
  const menuButton = document.querySelector('[data-menu-button]');
  const mobileMenu = document.querySelector('[data-mobile-menu]');

  const updateHeader = () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 10);
  };

  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });

  menuButton?.addEventListener('click', () => {
    const isOpen = menuButton.getAttribute('aria-expanded') === 'true';
    menuButton.setAttribute('aria-expanded', String(!isOpen));
    if (mobileMenu instanceof HTMLElement) {
      mobileMenu.hidden = isOpen;
    }
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid transparent;
    background: rgba(11, 16, 32, 0.48);
    backdrop-filter: blur(18px);
    transition: background 180ms ease, border-color 180ms ease;
  }

  .site-header.is-scrolled {
    border-color: var(--color-border);
    background: rgba(11, 16, 32, 0.82);
  }

  .nav-shell {
    display: grid;
    min-height: 78px;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 1.4rem;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .desktop-nav {
    justify-content: center;
  }

  a {
    color: var(--color-fog);
    font-size: 0.92rem;
    font-weight: 700;
    transition: color 180ms ease;
  }

  a:hover {
    color: var(--color-paper);
  }

  .external-nav a {
    color: var(--color-electric-cyan);
  }

  .menu-button {
    display: none;
    width: 44px;
    height: 44px;
    place-items: center;
    border: 1px solid var(--color-border-strong);
    border-radius: 14px;
    background: rgba(229, 231, 235, 0.06);
    color: var(--color-paper);
  }

  .menu-button span[aria-hidden="true"],
  .menu-button span[aria-hidden="true"]::before,
  .menu-button span[aria-hidden="true"]::after {
    display: block;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    content: "";
  }

  .menu-button span[aria-hidden="true"]::before {
    transform: translateY(-7px);
  }

  .menu-button span[aria-hidden="true"]::after {
    transform: translateY(5px);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .mobile-menu {
    border-top: 1px solid var(--color-border);
    background: rgba(11, 16, 32, 0.96);
  }

  .mobile-menu nav {
    display: grid;
    gap: 0;
    padding-block: 0.75rem;
  }

  .mobile-menu a {
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(229, 231, 235, 0.08);
  }

  @media (max-width: 980px) {
    .nav-shell {
      grid-template-columns: auto 1fr auto;
    }

    .desktop-nav,
    .external-nav {
      display: none;
    }

    .menu-button {
      display: grid;
      justify-self: end;
    }
  }
</style>
