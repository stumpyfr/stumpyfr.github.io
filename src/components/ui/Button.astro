---
import { externalLinkAttrs } from '@/config/site';

interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  external?: boolean;
}

const { href, variant = 'primary', external = false } = Astro.props;
const attrs = external ? externalLinkAttrs() : {};
---

<a class:list={['button', variant]} href={href} {...attrs}>
  <slot />
</a>

<style>
  .button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border-radius: 15px;
    padding: 0.78rem 1.05rem;
    border: 1px solid var(--color-border-strong);
    color: var(--color-paper);
    font-weight: 700;
    line-height: 1;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease, box-shadow 180ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .primary {
    border-color: rgba(34, 211, 238, 0.42);
    background: linear-gradient(135deg, rgba(34, 211, 238, 0.24), rgba(59, 130, 246, 0.22));
    box-shadow: var(--shadow-glow-cyan);
  }

  .secondary {
    background: rgba(229, 231, 235, 0.07);
  }

  .ghost {
    min-height: 40px;
    padding: 0.55rem 0;
    border-color: transparent;
    color: var(--color-electric-cyan);
  }

  .ghost:hover {
    box-shadow: none;
  }
</style>
