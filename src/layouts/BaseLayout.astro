---
import SiteFooter from '@/components/layout/SiteFooter.astro';
import SiteHeader from '@/components/layout/SiteHeader.astro';
import { absoluteUrl, siteConfig } from '@/config/site';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  canonicalPath = Astro.url.pathname,
  image = siteConfig.assets.og,
  jsonLd,
} = Astro.props;

const pageTitle = title === siteConfig.title ? title : `${title} — ${siteConfig.name}`;
const canonical = absoluteUrl(canonicalPath);
const imageUrl = absoluteUrl(image);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href={siteConfig.assets.favicon} />
    <link rel="apple-touch-icon" href={siteConfig.assets.appleTouchIcon} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1731" />
    <meta property="og:image:height" content="909" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
